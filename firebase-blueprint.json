{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "email": { "type": "string", "description": "User email" },
        "role": { "type": "string", "enum": ["admin", "user"], "description": "User role" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Account creation timestamp" },
        "lastIp": { "type": "string", "description": "Last recorded IP address" },
        "accessExpiresAt": { "type": "string", "format": "date-time", "description": "When the user's access expires" }
      },
      "required": ["uid", "email", "role", "createdAt"]
    },
    "Chat": {
      "title": "Chat",
      "description": "A conversation session",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Chat ID" },
        "userId": { "type": "string", "description": "Owner UID" },
        "title": { "type": "string", "description": "Chat title" },
        "lastMessageAt": { "type": "string", "format": "date-time", "description": "Last message timestamp" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp" }
      },
      "required": ["id", "userId", "title", "lastMessageAt", "createdAt"]
    },
    "Message": {
      "title": "Message",
      "description": "A single message in a chat",
      "type": "object",
      "properties": {
        "role": { "type": "string", "enum": ["user", "model"], "description": "Sender role" },
        "content": { "type": "string", "description": "Message text" },
        "imageData": { "type": "string", "description": "Base64 image data (optional)" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Message timestamp" }
      },
      "required": ["role", "content", "createdAt"]
    },
    "AccessCode": {
      "title": "AccessCode",
      "description": "Codes required for account creation",
      "type": "object",
      "properties": {
        "code": { "type": "string", "description": "The access code" },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the code was generated" },
        "expiresAt": { "type": "string", "format": "date-time", "description": "When the code expires (30 days after creation)" },
        "used": { "type": "boolean", "description": "Whether the code has been used" },
        "usedBy": { "type": "string", "description": "UID of the user who used the code" },
        "usedByEmail": { "type": "string", "description": "Email of the customer who bought the code" },
        "isPermanent": { "type": "boolean", "description": "Whether the code is a permanent admin key" }
      },
      "required": ["code", "createdAt", "expiresAt", "used"]
    }
  },
  "firestore": {
    "/users/{uid}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/accessCodes/{code}": {
      "schema": "AccessCode",
      "description": "Access codes for registration"
    },
    "/chats/{chatId}": {
      "schema": "Chat",
      "description": "User chat sessions"
    },
    "/chats/{chatId}/messages/{messageId}": {
      "schema": "Message",
      "description": "Messages within a chat"
    }
  }
}
