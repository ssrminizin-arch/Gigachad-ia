rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Fields: uid, email, role, createdAt, lastIp, accessExpiresAt
    //
    // Collection: chats
    // Fields: userId, title, createdAt, lastMessageAt
    //
    // Collection: messages
    // Fields: role, content, imageData, createdAt
    //
    // Collection: accessCodes
    // Fields: code, createdAt, expiresAt, used, usedBy, isPermanent
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         (request.auth.token.email == "afizportapau@gmail.com" && request.auth.token.email_verified == true));
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function isValidUser(data) {
      return hasOnlyAllowedFields(['uid', 'email', 'role', 'createdAt', 'lastIp', 'accessExpiresAt']) &&
             data.uid == request.auth.uid &&
             data.role in ['admin', 'user'];
    }

    function isValidChat(data) {
      return hasOnlyAllowedFields(['userId', 'title', 'createdAt', 'lastMessageAt']) &&
             data.userId == request.auth.uid &&
             data.title is string && data.title.size() <= 100;
    }

    function isValidMessage(data) {
      return hasOnlyAllowedFields(['role', 'content', 'imageData', 'createdAt']) &&
             data.role in ['user', 'model'] &&
             data.content is string && data.content.size() <= 10000;
    }

    // Users Collection
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if (isOwner(userId) && isValidUser(request.resource.data)) || isAdmin();
    }

    // Access Codes Collection
    match /accessCodes/{code} {
      allow get: if true; 
      allow list: if isAdmin();
      allow create, update, delete: if isAdmin();
    }

    // Chats Collection
    match /chats/{chatId} {
      allow read, delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && isValidChat(request.resource.data);
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid && isValidChat(request.resource.data);

      // Messages Subcollection
      match /messages/{messageId} {
        allow read: if isAuthenticated() && get(/databases/$(database)/documents/chats/$(chatId)).data.userId == request.auth.uid;
        allow create: if isAuthenticated() && get(/databases/$(database)/documents/chats/$(chatId)).data.userId == request.auth.uid && isValidMessage(request.resource.data);
      }
    }
  }
}
